{
  "mcpServers": {
    "postiz": {
      "command": "npx",
      "args": ["-y", "postiz"],
      "env": {
        "POSTIZ_API_KEY": "${POSTIZ_API_KEY}",
        "POSTIZ_API_URL": "${POSTIZ_API_URL}"
      }
    },
    "composio": {
      "command": "npx",
      "args": ["-y", "@composio/mcp"],
      "env": {
        "COMPOSIO_API_KEY": "${COMPOSIO_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  }
}
