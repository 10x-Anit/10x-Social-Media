# ── Postiz Connection (REQUIRED) ──────────────────────────────
POSTIZ_BASE_URL=http://localhost:4200
POSTIZ_API_KEY=your_api_key_here

# ── Telegram (optional) ──────────────────────────────────────
# Create bot via @BotFather on Telegram → get token
TELEGRAM_BOT_TOKEN=

# ── Slack (optional) ─────────────────────────────────────────
# Create app at api.slack.com/apps → enable Socket Mode
# Bot Token: OAuth & Permissions → Bot User OAuth Token (xoxb-...)
# App Token: Basic Information → App-Level Tokens (xapp-...)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Discord (optional) ───────────────────────────────────────
# Create bot at discord.com/developers → Bot → Token
# NOTE: This is the CHAT BOT token, separate from Postiz's
# DISCORD_CLIENT_ID/SECRET which are for social posting
DISCORD_CHAT_BOT_TOKEN=

# ── WhatsApp (optional) ──────────────────────────────────────
# Set to true, then scan QR code on first run
# No API keys needed — authenticates via WhatsApp Web QR
WHATSAPP_ENABLED=false
