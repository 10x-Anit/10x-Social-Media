## ============================================================
## [F:CONFIG.01] Environment Variables Template
## ============================================================
## Copy to project root as .env and fill in your values.
## See docs/VARIABLES.md for full documentation on each variable.
## ============================================================

## ── Base URL (THE ONLY THING TO CHANGE WHEN MIGRATING) ───────
POSTIZ_BASE_URL=http://localhost:4200

## ── Derived URLs ─────────────────────────────────────────────
MAIN_URL=http://localhost:4200
FRONTEND_URL=http://localhost:4200
NEXT_PUBLIC_BACKEND_URL=http://localhost:4200/api

## ── Ports ────────────────────────────────────────────────────
POSTIZ_PORT=4200
MCP_PORT=3084
TEMPORAL_UI_PORT=8080

## ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME

## ── Postiz API ───────────────────────────────────────────────
POSTIZ_API_KEY=REPLACE_AFTER_FIRST_LOGIN
POSTIZ_MCP_URL=http://localhost:3084/sse

## ── Platform Keys (add as needed) ────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
X_API_KEY=
X_API_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

## ── Optional ─────────────────────────────────────────────────
OPENAI_API_KEY=
DISABLE_REGISTRATION=false
