## ============================================================
## 10x Social Media — Environment Configuration
## ============================================================
## DO NOT EDIT THIS FILE DIRECTLY.
## Run /setup in Claude Code — it will create your .env for you.
## This file is the template that /setup copies from.
## ============================================================

## ── Base URL ─────────────────────────────────────────────────
## Local: http://localhost:4200
## Server: https://your-domain.com
POSTIZ_BASE_URL=http://localhost:4200
MAIN_URL=http://localhost:4200
FRONTEND_URL=http://localhost:4200
NEXT_PUBLIC_BACKEND_URL=http://localhost:4200/api

## ── Port ─────────────────────────────────────────────────────
POSTIZ_PORT=4200

## ── Auth (auto-generated by /setup) ──────────────────────────
JWT_SECRET=WILL_BE_AUTO_GENERATED

## ── Postiz API Key (get from dashboard after account creation) ─
POSTIZ_API_KEY=WILL_BE_SET_DURING_SETUP

## ── Temporal Cloud (scheduling engine) ───────────────────────
## Get these from cloud.temporal.io
TEMPORAL_ADDRESS=WILL_BE_SET_DURING_SETUP
TEMPORAL_NAMESPACE=WILL_BE_SET_DURING_SETUP
TEMPORAL_API_KEY=WILL_BE_SET_DURING_SETUP

## ── Social Media Platform Keys ───────────────────────────────
## These get filled in during /setup for each platform you connect.
## Get credentials from each platform's developer portal.

## LinkedIn (developer.linkedin.com)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

## Twitter / X (developer.x.com)
X_API_KEY=
X_API_SECRET=

## Facebook + Instagram (developers.facebook.com)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

## TikTok (developers.tiktok.com)
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

## YouTube (console.cloud.google.com)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

## Reddit (reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

## Pinterest (developers.pinterest.com)
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

## Threads (developers.facebook.com — same Meta app as FB/IG)
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

## Discord (discord.com/developers)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

## Mastodon (your instance's /settings/applications)
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

## Dribbble (dribbble.com/account/applications)
DRIBBBLE_CLIENT_ID=
DRIBBBLE_CLIENT_SECRET=

## ── Optional: AI in Dashboard ────────────────────────────────
## Not required — Claude Code IS your AI layer.
## Only set if you want Postiz dashboard AI assistant too.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

## ── Registration ─────────────────────────────────────────────
DISABLE_REGISTRATION=false
